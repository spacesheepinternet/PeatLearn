# Keep the build context (and image) small — exclude everything the API
# serve path does not need.

# Virtualenv / Python caches
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Data: exclude everything EXCEPT the cleaned source texts, which the
# full-document endpoint serves (~18 MB). Docker can't re-include a child if
# its parent dir is excluded outright, so exclude *contents* at each level
# then re-include the one path we want.
data/*
!data/processed
data/processed/*
!data/processed/ai_cleaned
*.npy
*.pkl
*.npz

# Local dev / tooling
.git/
.github/
.claude/
tests/
docs/
preprocessing/
scripts/
notebooks/
council-sessions/
*.md
HANDOFF.md

# Secrets — provided at runtime via --env-file / platform env vars
.env
.env.*

# Frontend (built and deployed separately)
web/
node_modules/

# OS noise
.DS_Store
Thumbs.db
